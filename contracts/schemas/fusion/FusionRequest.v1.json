{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:quantwin:schema:fusion:FusionRequest:v1",
  "title": "FusionRequest.v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["tenant_id", "evidence_list"],
  "properties": {
    "tenant_id": { "type": "string", "minLength": 1 },
    "mode": { "type": "string", "enum": ["STRICT", "BALANCED", "FAST"], "default": "BALANCED" },
    "max_evidence": { "type": "integer", "minimum": 1, "maximum": 50, "default": 10 },
    "evidence_list": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["evidence_id", "source", "snippet", "score"],
        "properties": {
          "evidence_id": { "type": "string", "minLength": 1 },
          "source": { "type": "string", "minLength": 1 },
          "snippet": { "type": "string", "minLength": 1 },
          "score": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    }
  }
}
