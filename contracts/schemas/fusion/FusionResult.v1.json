{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:quantwin:schema:fusion:FusionResult:v1",
  "title": "FusionResult.v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["trace_id", "fused_summary", "used_evidence_ids"],
  "properties": {
    "trace_id": { "type": "string", "minLength": 1 },
    "fused_summary": { "type": "string", "minLength": 1 },
    "used_evidence_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "results_by_source": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string", "minLength": 1 }
      },
      "default": {}
    }
  }
}
