{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quantwin/contracts/devloop/chatgpt_result.schema.json",
  "title": "ChatGPT Specialist Result Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "trace_id",
    "run_id",
    "audit_id",
    "status",
    "summary",
    "files_touched",
    "changes",
    "commands_to_run",
    "self_check",
    "rollback",
    "generated_at"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "audit_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "SUCCESS",
        "BLOCKED",
        "ERROR"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "files_touched": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "changes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "action",
          "rationale"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "action": {
            "type": "string",
            "enum": [
              "create",
              "modify",
              "delete",
              "none"
            ]
          },
          "rationale": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "commands_to_run": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "self_check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "checks"
      ],
      "properties": {
        "checks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "rollback": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "steps"
      ],
      "properties": {
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    }
  }
}
